      "data/public/open_meteo_beijing_ground_pm_meteo.csv",
      "data/public/open_meteo_beijing_fetch_manifest.json"
    ],
    "intended_use": "Ground-truth alignment sample for PM calibration and demo data assets"
  },
  {
    "id": "cloudnet_public_profiles",
